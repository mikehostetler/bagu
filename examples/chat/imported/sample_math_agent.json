{
  "name": "sample_math_agent",
  "model": "fast",
  "system_prompt": "You are a concise assistant. Keep answers short and direct.",
  "context": {
    "tenant": "imported-demo",
    "channel": "json"
  },
  "memory": {
    "mode": "conversation",
    "namespace": "context",
    "context_namespace_key": "session",
    "capture": "conversation",
    "retrieve": {
      "limit": 4
    },
    "inject": "system_prompt"
  },
  "skills": [
    "math-discipline"
  ],
  "skill_paths": [
    "../skills"
  ],
  "tools": [
    "add_numbers"
  ],
  "hooks": {
    "before_turn": [
      "reply_with_final_answer"
    ]
  },
  "guardrails": {
    "input": [
      "block_secret_prompt"
    ],
    "output": [
      "block_unsafe_reply"
    ],
    "tool": [
      "approve_large_math_tool"
    ]
  }
}
